{
  "name": "expense-tracker-devops",
  "version": "1.0.0",
  "description": "Expense tracker with MongoDB and DevOps pipeline",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "lint": "eslint .",
    "build": "echo Build successful",
    "docker:build": "docker build -t expense-tracker .",
    "docker:run": "docker run -p 3000:3000 expense-tracker",
    "docker:up": "docker-compose up --build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mongodb": "^7.1.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "keywords": [
    "expense-tracker",
    "mongodb",
    "devops",
    "docker",
    "ci"
  ],
  "author": "",
  "license": "ISC"
}